# ClawHalla .gitignore

# Environment
.env
.env.local
.env.*.local

# Volumes (keep structure, ignore data)
volumes/openclaw/*
!volumes/openclaw/.gitkeep

# Node
node_modules/
.pnpm-store/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Build artifacts
dist/
build/

# Solidity build artifacts
contracts/cache/
contracts/out/

# Mission Control
apps/mission-control/node_modules/
apps/mission-control/.next/
apps/mission-control/.env
apps/mission-control/data/
apps/mission-control/*.db

# Workspace data (user-specific, never commit)
volumes/
workspace-template/company/org_structure.yaml
